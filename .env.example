# Change this to a strong password before exposing the app to others.
# If left empty, authentication is disabled.
SHAREBOX_PASSWORD=share

# Server port
PORT=3940

# Enable only when ShareBox is behind a trusted reverse proxy that sets forwarding headers.
# TRUST_PROXY=true

# Enable when the app is served over HTTPS so the session cookie is sent only on secure requests.
# COOKIE_SECURE=true
